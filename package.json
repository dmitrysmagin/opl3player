{
    "name": "opl3player",
    "version": "0.5.0",
    "description": "OPL3 player with AudioWorklet",
    "main": "dist/opl3.js",
    "scripts": {
        "dev": "vite",
        "build:worklet": "vite build --mode worklet",
        "build": "npm run build:worklet && vite build",
        "typecheck": "tsc --noEmit",
        "lint": "./node_modules/.bin/eslint -c ./.eslintrc.json lib/**/*.js ./*.js",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/dmitrysmagin/opl3.git"
    },
    "keywords": [
        "opl",
        "opl3",
        "YMF262",
        "javascript",
        "sound",
        "blaster",
        "music",
        "doom",
        "dosbox",
        "laa",
        "mus",
        "dro",
        "imf",
        "raw"
    ],
    "author": "IDDQD",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/doomjs/opl3/issues"
    },
    "homepage": "https://github.com/doomjs/opl3#readme",
    "devDependencies": {
        "typescript": "^5.9.3",
        "vite": "^5.4.21"
    }
}
